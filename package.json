{
  "name": "pkg-action-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Official GitHub Action for @yao-pkg/pkg — monorepo root.",
  "repository": {
    "type": "git",
    "url": "https://github.com/yao-pkg/pkg-action.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node --experimental-strip-types scripts/bundle.ts",
    "gen": "node --experimental-strip-types scripts/gen-action-yml.ts",
    "test": "node --test --experimental-strip-types --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage.lcov --test-reporter=spec --test-reporter-destination=stdout 'packages/**/test/**/*.test.ts'",
    "test:unit": "node --test --experimental-strip-types 'packages/*/test/unit/**/*.test.ts'",
    "test:int": "node --test --experimental-strip-types 'packages/*/test/integration/**/*.test.ts'",
    "test:watch": "node --test --watch --experimental-strip-types 'packages/*/test/unit/**/*.test.ts'",
    "lint": "yarn lint:code && yarn lint:style",
    "lint:code": "eslint 'packages/**/src/**/*.ts' 'scripts/**/*.ts'",
    "lint:style": "prettier --check .",
    "fix": "eslint --fix 'packages/**/src/**/*.ts' 'scripts/**/*.ts' && prettier --write .",
    "typecheck": "tsc --noEmit -p ."
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.0",
    "typescript": "6.0.3"
  }
}
